PORT=5000
APP_URL=http://localhost:5000

# CORS — Next.js local (nhiều origin cách nhau bởi dấu phẩy)
CORS_ORIGIN=http://localhost:3000

# SQLite
DATABASE_PATH=data/automations.sqlite

# BullMQ — chỉ bật khi đã có Redis chạy
QUEUE_ENABLED=false
# REDIS_HOST=localhost
# REDIS_PORT=6379

# n8n — true = dùng /webhook/ (production), false = /webhook-test/ (listen 1 lần)
N8N_USE_PRODUCTION_WEBHOOK=true
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_PATH=68c98953-6269-4555-851e-670da5d87045
# N8N_WEBHOOK_TEST_URL=http://localhost:5678/webhook-test/68c98953-6269-4555-851e-670da5d87045

# n8n callback auth (optional)
# N8N_CALLBACK_SECRET=your-secret
