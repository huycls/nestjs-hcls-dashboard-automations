PORT=5000
APP_URL=http://localhost:5000

# CORS — Next.js local (nhiều origin cách nhau bởi dấu phẩy)
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/hcls-automations

# JWT auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Admin seed — dùng với npm run seed:admin
ADMIN_EMAIL=admin@hcls.local
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Admin

# BullMQ — chỉ bật khi đã có Redis chạy
QUEUE_ENABLED=false
# REDIS_HOST=localhost
# REDIS_PORT=6379
MONGODB_CONNECTION_STRING=mongodb://huypremium_db_user:E8C3vEy47nWNNW1r@ac-kl5kyxg-shard-00-00.8qfa6gt.mongodb.net:27017,ac-kl5kyxg-shard-00-01.8qfa6gt.mongodb.net:27017,ac-kl5kyxg-shard-00-02.8qfa6gt.mongodb.net:27017/hcls-automations?authSource=admin&replicaSet=atlas-2zelva-shard-0&tls=true&retryWrites=true&w=majority
# n8n — true = dùng /webhook/ (production), false = /webhook-test/ (listen 1 lần)
N8N_USE_PRODUCTION_WEBHOOK=true
N8N_BASE_URL=https://flow.avispark.com
N8N_GEN_IDEAS_WEBHOOK_PATH=68c98953-6269-4555-851e-670da5d87045
N8N_GEN_CONTENT_WEBHOOK_PATH=cf4fff04-479a-4773-8c14-33bca67af8fa
# N8N_WEBHOOK_TEST_URL=http://localhost:5678/webhook-test/tJzVZLs9LEmdR6WH

# n8n callback / error / success reporting (optional)
# N8N_CALLBACK_SECRET=your-secret
# n8n gửi header: x-n8n-callback-secret: your-secret
# POST|PUT /api/jobs/success — thành công: +1 triggers, restore workflow status
# POST /api/jobs/error     — lỗi: workflow status = Failed
# POST /api/jobs/callback  — legacy { status: "completed" | "failed" }
# Dùng host.docker.internal thay localhost nếu n8n chạy Docker
# APP_URL=http://host.docker.internal:5000
